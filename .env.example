# Supabase (Auth + client API)
# Local: ./scripts/setup.sh maps supabase status → these keys
# Hosted: Project Settings → API (Project URL, anon key, service_role key)
#         or op://Frontenac Studios/Supabase <Project>/...
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Drizzle — server-side Postgres connection string)
# Local: setup.sh maps DB_URL from `npm run supabase -- status -o env` → DATABASE_URL
# Hosted: dashboard → Connect → Transaction pooler (port 6543); replace [YOUR-PASSWORD]
#         with database password (Settings → Database → Reset database password)
# Example: postgresql://postgres.[ref]:[password]@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Anthropic — server-only (Kash Claude companion)
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=

# Proactive Top-3 nudges — optional dev overrides (default threshold: 2pm local)
# NUDGE_DEBUG_HOUR=12
# NEXT_PUBLIC_NUDGE_DEBUG_HOUR=12

# Desktop (Tauri macOS — local sidecar)
# DATABASE_MODE=sqlite
# KASH_DESKTOP=1
# KASH_DATA_DIR=~/Library/Application Support/Kash
# KASH_SIDECAR_PORT=4310

# E2E (Playwright — local/CI only)
# E2E_USER_EMAIL=e2e@kash.test
# E2E_USER_PASSWORD=e2e-test-password-12!

# Sentry — Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Source map upload (Vercel + CI only — never commit)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=frontenac-studios
# SENTRY_PROJECT=<your-sentry-project-slug>
