# Supabase
# Local: values from `npm run supabase -- status -o env`
# Hosted: op://Frontenac Studios/Supabase <Project>/url (and anon_key, service_role_key sections)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (used by Drizzle)
# Local: DB_URL from `npm run supabase -- status -o env`
# Hosted: postgresql://postgres.[ref]:[password]@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Sentry — Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Source map upload (Vercel + CI only — never commit)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=frontenac-studios
# SENTRY_PROJECT=<your-sentry-project-slug>