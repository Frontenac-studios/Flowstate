{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default Kash desktop capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:webview:allow-internal-toggle-devtools",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-execute"
  ]
}
